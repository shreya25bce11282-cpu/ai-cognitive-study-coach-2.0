DB_USER=postgres
DB_HOST=localhost
DB_NAME=studycoach
DB_PASSWORD=changeme
DB_PORT=5432
PORT=5000

# Used to sign login tokens. Generate a random one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=changeme

# Optional. If set, the /api/analytics/ai-insight endpoint calls the
# Anthropic API for a genuinely personalized insight. If unset, that
# endpoint falls back to a rule-based summary instead — the app still
# works fully without this.
ANTHROPIC_API_KEY=
